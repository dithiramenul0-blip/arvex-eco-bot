# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arvex-bot
MONGODB_DB_NAME=arvex-bot

# Environment
NODE_ENV=production

# Bot Configuration
PREFIX=ax!
OWNER_ID=your_discord_user_id
DEV_SERVER_ID=your_dev_server_id

# Logging
LOG_LEVEL=info
LOG_WEBHOOK_URL=your_webhook_url_for_logging

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0

# Security
SECRET_KEY=your_secret_key_for_encryption
ENCRYPTION_ALGORITHM=aes-256-cbc

# Feature Flags
ENABLE_ECONOMY=true
ENABLE_QUESTS=true
ENABLE_LEVELING=true
ENABLE_HOSTING_REWARDS=true
ENABLE_MODERATION=true
ENABLE_TICKETS=true
ENABLE_GIVEAWAYS=true
ENABLE_DASHBOARD=false
